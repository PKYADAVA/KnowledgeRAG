# ─── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-django-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://raguser:ragpassword@localhost:5432/knowledgerag

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_LLM_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# ─── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=knowledge-rag
PINECONE_ENVIRONMENT=us-east-1
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ─── RAG Config ────────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7

# ─── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,txt,md

# ─── Security ──────────────────────────────────────────────────────────────────
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password

# ─── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_CHAT=10/m
RATE_LIMIT_UPLOAD=5/m
